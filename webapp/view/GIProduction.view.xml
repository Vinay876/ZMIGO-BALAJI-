<mvc:View
    xmlns:rowmodes="sap.ui.table.rowmodes"
    controllerName="zmigo.controller.GIProduction"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:m="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:table="sap.ui.table"
    height="100%"
>
    <m:Page
        id="page"
        title="GOODS ISSUE (PRODUCTION ORDER)"
        enableScrolling="true"
    >
        <m:content>
            <m:Panel
                width="auto"
                id="headerPanel"
                headerText="Header Details"
                expandable="true"
                expanded="true"
                class="sapUiResponsiveMargin"
            >
                <m:content>
                    <f:SimpleForm
                        id="_IDGenSimpleForm"
                        editable="true"
                        layout="ResponsiveGridLayout"
                        singleContainerFullSize="false"
                        adjustLabelSpan="false"
                        labelSpanL="3"
                        labelSpanM="3"
                        columnsL="2"
                        columnsM="2"
                    >
                        <f:content>
                            <core:Title
                                id="_IDGenTitle1"
                                text=""
                            />
                            <m:Label
                                id="_IDGenLabel7"
                                text="Production Order"
                                design="Bold"
                            />
                            <m:Input
                                id="inOrder"
                                width="100%"
                                value="{Header>/ManufacturingOrder}"
                                showValueHelp="true"
                                editable="{= !${Header>/orderSelected}}"
                                required="true"
                                valueHelpRequest=".onPOValueHelp"
                            />

                            <m:Label
                                id="_IDGenLabel9"
                                text="Document Date"
                            />
                            <m:DatePicker
                                id="inDocDate"
                                value="{Header>/DocumentDate}"
                                displayFormat="dd-MM-yyyy"
                                valueFormat="yyyy-MM-ddTHH:mm:ss"
                                enabled="{Header>/fieldsEnabled}"
                            />

                            <m:Label
                                id="_IDGenLabel10"
                                text="Posting Date"
                            />
                            <m:DatePicker
                                id="inPostDate"
                                valueFormat="yyyy-MM-ddTHH:mm:ss"
                                displayFormat="dd-MM-yyyy"
                                value="{Header>/PostingDate}"
                                enabled="{Header>/fieldsEnabled}"
                            />

                            <!-- <m:Label
                                id="_IDGenLabel11"
                                text="Nos/Pallet(Dist. QTY)"
                            />
                            <m:Input
                                id="_IDGenInput1"
                                value="{HEADER>/DistQty}"
                            /> -->

                            <core:Title
                                id="_IDGenTitle2"
                                text=""
                            />
                            <m:Label
                                id="_IDGenLabel8"
                                text="Movement Type"
                                design="Bold"
                            />
                            <m:Input
                                id="inMovType"
                                width="120px"
                                value="{Header>/MoveType}"
                                editable="false"
                            />

                            <m:Label
                                id="_IDGenLabel12"
                                text="Doc. Header Text"
                            />
                            <m:Input
                                id="_IDGenInput2"
                                value="{Header>/HeaderText}"
                            />

                            <m:Label
                                id="_IDGenLabel13"
                                text="Delivery Note"
                            />
                            <m:Input
                                id="_IDGenInput3"
                                value="{Header>/RefernceDocument}"
                            />

                            <!-- <m:Label
                                id="_IDGenLabel14"
                                text="Order Type"
                            />
                            <m:Input
                                id="_IDGenInput4"
                                value="{HEADER>/OrderType}"
                            /> -->
                        </f:content>
                    </f:SimpleForm>
                </m:content>
            </m:Panel>

            <m:Panel
                width="auto"
                id="materialPanel"
                headerText="{= 'Material Details (' + ${Header>/ProdItems}.length + ')'}"
                expandable="true"
                expanded="false"
                class="sapUiResponsiveMargin"
            >
                <m:content>
                    <table:Table
                        id="_IDGenTable"
                        rows="{Header>/ProdItems}"
                        selectionMode="MultiToggle"
                    >
                        <table:extension>
                            <m:OverflowToolbar id="_IDGenOverflowToolbar3">
                                <m:ToolbarSpacer id="_IDGenToolbarSpacer3" />
                                <m:Button
                                    id="_IDGenButtonAdd"
                                    text="Add Line"
                                    icon="sap-icon://add"
                                    type="Emphasized"
                                    press="onAddMaterialLine"
                                />
                                <m:Button
                                    id="_IDGenButtonDelMat"
                                    text="Delete"
                                    icon="sap-icon://delete"
                                    type="Reject"
                                    press="onDeleteMaterialLine"
                                />
                            </m:OverflowToolbar>
                        </table:extension>

                        <table:rowMode>
                            <rowmodes:Fixed
                                id="_IDGenFixed"
                                rowCount="5"
                            />
                        </table:rowMode>
                        <table:columns>
                            <table:Column
                                id="_IDGenColumn6"
                                width="12rem"
                            >
                                <m:Label
                                    id="_IDGenLabel1"
                                    text="Material"
                                />
                                <table:template>
                                    <m:Input
                                        id="_IDGenText"
                                        editable="{= !${Header>AutoEdit}}"
                                        value="{Header>Material}"
                                        required="true"
                                        valueHelpRequest=".onProductValueHelp"
                                        showValueHelp="true"
                                    />
                                </table:template>
                            </table:Column>
                            <table:Column
                                id="_IDGenColumn19"
                                width="12rem"
                            >
                                <m:Label
                                    id="_IDGenLabel31"
                                    text="Name"
                                />
                                <table:template>
                                    <m:Text
                                        id="_IDGenText19"
                                        text="{Header>ProductName}"
                                    />
                                </table:template>
                            </table:Column>
                            <table:Column
                                id="_IDGenColumn1"
                                width="15rem"
                            >
                                <m:Label
                                    id="_IDGenLabel2"
                                    text="Quantity"
                                />
                                <table:template>
                                    <m:Input
                                        id="_IDGenText1"
                                        editable="true"
                                        type="Number"
                                        value="{Header>Quantity}"
                                       liveChange=".onQuantityChange"
                                    />
                                </table:template>
                            </table:Column>
                            <table:Column
                                id="_IDGenColumn2"
                                width="10rem"
                            >
                                <m:Label
                                    id="_IDGenLabel3"
                                    text="Unit"
                                />
                                <table:template>
                                    <m:Text
                                        id="_IDGenInput"
                                        text="{Header>Unit}"
                                    />
                                </table:template>
                            </table:Column>
                            <table:Column
                                id="_IDGenColumn7"
                                width="15rem"
                            >
                                <m:Label
                                    id="_IDGenLabel"
                                    text="Movement Type"
                                />
                                <table:template>
                                    <m:Text
                                        id="_IDGenText5"
                                        text="{Header>MoveType}"
                                    />
                                </table:template>
                            </table:Column>
                            <table:Column
                                id="_IDGenColumn8"
                                width="10rem"
                            >
                                <m:Label
                                    id="_IDGenLabel15"
                                    text="Converted Quantity"
                                />
                                <table:template>
                                    <m:Text
                                        id="_IDGenInput5"
                                        text="{Header>QtyConv}"
                                        
                                    />
                                </table:template>
                            </table:Column>
                             <table:Column
                                id="_IDGenColumn81"
                                width="10rem"
                            >
                                <m:Label
                                    id="_IDGenLabel151"
                                    text="Converted Unit"
                                />
                                <table:template>
                                    <m:Text
                                        id="_IDGenInput51"
                                        text="{Header>AlternativeUnit}"
                                    />
                                </table:template>
                            </table:Column>
                            <table:Column
                                id="_IDGenColumn9"
                                width="14rem"
                            >
                                <m:Label
                                    id="_IDGenLabel16"
                                    text="Plant"
                                />
                                <table:template>
                                    <m:Text
                                        id="_IDGenInput6"
                                        text="{Header>Plant}"
                                    />
                                </table:template>
                            </table:Column>
                            <table:Column
                                id="_IDGenColumn15"
                                width="14rem"
                            >
                                <m:Label
                                    id="_IDGenLabel20"
                                    text="Storage Location"
                                />
                                <table:template>
                                    <m:Input
                                        id="_IDGenText9"
                                        editable="{= !${Header>AutoEdit}}"
                                        value="{Header>Location}"
                                        required="true"
                                        valueHelpRequest=".onLocationValueHelp"
                                        showValueHelp="true"
                                    />
                                </table:template>
                            </table:Column>
                            <table:Column
                                id="_IDGenColumn10"
                                width="14rem"
                            >
                                <m:Label
                                    id="_IDGenLabel17"
                                    text="Batch Number"
                                />
                                <table:template>
                                    <m:Input
                                        id="_IDGenInput7"
                                        value="{Header>Batch}"
                                        required="true"
                                        valueHelpRequest=".onBatchValueHelp"
                                        showValueHelp="true"
                                        editable="{Header>BatchEditable}"
                                    />
                                </table:template>
                            </table:Column>
                        </table:columns>
                    </table:Table>
                </m:content>
            </m:Panel>

            <m:Panel
                width="auto"
                id="itemPanel"
                headerText="{= 'Batch Distribution Details (' + ${Header>/ProdDividedItem}.length + ')'}"
                expandable="true"
                expanded="true"
                class="sapUiResponsiveMargin"
            >
                <m:content>
                    <table:Table
                        id="TreeTableBasic"
                        rows="{Header>/ProdDividedItem}"
                        selectionMode="Single"
                        rowSelectionChange="OnDistriButionChange"
                    >
                        <table:rowMode>
                            <rowmodes:Fixed
                                id="_IDGenFixed1"
                                rowCount="5"
                            />
                        </table:rowMode>
                        <table:columns>
                            <table:Column
                                id="_IDGenColumn"
                                width="10rem"
                            >
                                <m:Label
                                    id="_IDGenLabel18"
                                    text="Material"
                                />
                                <table:template>
                                    <m:Text
                                        id="_IDGenText2"
                                        text="{Header>Material}"
                                    />
                                </table:template>
                            </table:Column>
                            <table:Column
                                id="_IDGenColumn23"
                                width="12rem"
                            >
                                <m:Label
                                    id="_IDGenLabel37"
                                    text="Name"
                                />
                                <table:template>
                                    <m:Text
                                        id="_IDGenText20"
                                        text="{Header>ProductName}"
                                    />
                                </table:template>
                            </table:Column>
                            <table:Column
                                id="_IDGenColumn4"
                                width="10rem"
                            >
                                <m:Label
                                    id="_IDGenLabel4"
                                    text="Batch"
                                />
                                <table:template>
                                    <m:Text
                                        id="_IDGenText3"
                                        text="{Header>Batch}"
                                    />
                                </table:template>
                            </table:Column>
                            <table:Column
                                id="_IDGenColumn24"
                                width="10rem"
                            >
                                <m:Label
                                    id="_IDGenLabe21"
                                    text="Movement Type"
                                />
                                <table:template>
                                    <m:Text
                                        id="_IDGenText22"
                                        text="{Header>Movementtype}"
                                    />
                                </table:template>
                            </table:Column>
                            <table:Column
                                id="_IDGenColumn5"
                                width="10rem"
                            >
                                <m:Label
                                    id="_IDGenLabel5"
                                    text="Quantity"
                                />
                                <table:template>
                                    <m:Input
                                        id="_IDGenInput8"
                                        value="{Header>Quantity}"
                                    />
                                </table:template>
                            </table:Column>
                            <table:Column
                                id="_IDGenColumn28"
                                width="10rem"
                            >
                                <m:Label
                                    id="_IDGenLabel30"
                                    text="Batch Quantity"
                                />
                                <table:template>
                                    <m:Text
                                        id="_IDGenInput12"
                                        text="{Header>BatchQuantity}"
                                    />
                                </table:template>
                            </table:Column>
                            <table:Column
                                id="_IDGenColumn25"
                                width="10rem"
                            >
                                <m:Label
                                    id="_IDGenLabe35"
                                    text="Unit"
                                />
                                <table:template>
                                    <m:Input
                                        id="_IDGenInput38"
                                        value="{Header>Unit}"
                                    />
                                </table:template>
                            </table:Column>
                        </table:columns>
                    </table:Table>
                </m:content>
            </m:Panel>

            <!-- Batch Classification -->
            <m:Panel
                width="auto"
                id="_IDGenPanel"
                headerText="{= 'Batch Classification Details (' + ${Header>/BatchClassifications}.length + ')'}"
                expandable="true"
                expanded="true"
                class="sapUiResponsiveMargin"
            >
                <m:content>
                    <table:Table
                        id="BatchClassificationTable"
                        rows="{Header>/BatchClassifications}"
                        selectionMode="MultiToggle"
                    >
                        <table:rowMode>
                            <rowmodes:Fixed
                                id="_IDGenFixed2"
                                rowCount="5"
                            />
                        </table:rowMode>
                        <table:columns>
                            <table:Column
                                id="_IDGenColumn13"
                                width="10rem"
                            >
                                <m:Label
                                    id="_IDGenLabel6"
                                    text="Material"
                                />
                                <table:template>
                                    <m:Text
                                        id="_IDGenText7"
                                        text="{Header>Material}"
                                    />
                                </table:template>
                            </table:Column>
                            <table:Column
                                id="_IDGenColumn27"
                                width="12rem"
                            >
                                <m:Label
                                    id="_IDGenLabel38"
                                    text="Name"
                                />
                                <table:template>
                                    <m:Text
                                        id="_IDGenText21"
                                        text="{Header>ProductName}"
                                    />
                                </table:template>
                            </table:Column>
                            <table:Column
                                id="_IDGenColumn14"
                                width="10rem"
                            >
                                <m:Label
                                    id="_IDGenLabel19"
                                    text="Batch"
                                />
                                <table:template>
                                    <m:Text
                                        id="_IDGenText8"
                                        text="{Header>Batch}"
                                    />
                                </table:template>
                            </table:Column>
                            <table:Column
                                id="_IDGenColumn11"
                                width="10rem"
                            >
                                <m:Label
                                    id="_IDGenLabel14"
                                    text="Characteristic"
                                />
                                <table:template>
                                    <m:Text
                                        id="_IDGenText6"
                                        text="{Header>CharcDescription}"
                                    />
                                </table:template>
                            </table:Column>
                            <table:Column
                                id="_IDGenColumn3"
                                width="10rem"
                            >
                                <m:Label
                                    id="_IDGenLabel11"
                                    text="Value"
                                />
                                <table:template>
                                    <m:Input
                                        id="_IDGenText4"
                                        value="{Header>CharcValue}"
                                    />
                                </table:template>
                            </table:Column>
                        </table:columns>
                    </table:Table>
                </m:content>
            </m:Panel>
        </m:content>

        <m:footer>
            <m:OverflowToolbar id="_IDGenOverflowToolbar1">
                <m:ToolbarSpacer id="_IDGenToolbarSpacer2" />
                <!-- <m:Button
                    id="_IDGenButton12"
                    text="Check"
                    type="Emphasized"
                    press=".onCheck"
                /> -->
                <m:Button
                    id="_IDGenButton1"
                    text="Post"
                    type="Emphasized"
                    press=".onPost"
                />
                <m:Button
                    id="_IDGenButton2"
                    text="Cancel"
                    press="onCancel"
                    type="Ghost"
                />
            </m:OverflowToolbar>
        </m:footer>
    </m:Page>
</mvc:View>
