<mvc:View
    xmlns:rowmodes="sap.ui.table.rowmodes"
    controllerName="zmigo.controller.GRProduction"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:m="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:table="sap.ui.table"
    height="100%"
>
    <m:Page
        id="_IDGenPage"
        title="GOODS RECEIPT (PRODUCTION ORDER)"
        enableScrolling="true"
    >
        <m:content>
            <m:Panel
                id="_IDGenPanel2"
                headerText="Header Details"
                expandable="true"
                expanded="true"
                class="sapUiResponsiveMargin"
                width="auto"
            >
                <m:content>
                    <f:SimpleForm
                        id="_IDGenSimpleForm1"
                        editable="true"
                        layout="ResponsiveGridLayout"
                        singleContainerFullSize="false"
                        adjustLabelSpan="false"
                        labelSpanL="3"
                        labelSpanM="3"
                        columnsL="2"
                        columnsM="2"
                    >
                        <f:content>
                            <core:Title
                                id="_IDGenTitle3"
                                text=""
                            />
                            <m:Label
                                id="_IDGenLabel21"
                                text="Production Order"
                                design="Bold"
                            />
                            <m:Input
                                id="_IDGenInput1"
                                width="100%"
                                value="{Header>/ManufacturingOrder}"
                                showValueHelp="true"
                                editable="{= !${Header>/orderSelected}}"
                                required="true"
                                valueHelpRequest=".onPOValueHelp"
                            />

                            <m:Label
                                id="_IDGenLabel22"
                                text="Document Date"
                            />
                            <m:DatePicker
                                id="_IDGenDatePicker"
                                value="{Header>/DocumentDate}"
                                valueFormat="yyyy-MM-ddTHH:mm:ss"
                                displayFormat="dd-MM-yyyy"
                                enabled="{Header>/fieldsEnabled}"
                            />

                            <m:Label
                                id="_IDGenLabel23"
                                text="Posting Date"
                            />
                            <m:DatePicker
                                id="_IDGenDatePicker1"
                                valueFormat="yyyy-MM-ddTHH:mm:ss"
                                displayFormat="dd-MM-yyyy"
                                value="{Header>/PostingDate}"
                                enabled="{Header>/fieldsEnabled}"
                            />

                            <m:Label
                                id="_IDGenLabel35"
                                text="Nos/Pallet(Dist. QTY)"
                            />
                            <m:Input
                                id="_IDGenInput13"
                                change="PalletChange"
                                value="{Header>/FilledQty}"
                            />

                            <core:Title
                                id="_IDGenTitle4"
                                text=""
                            />
                            <m:Label
                                id="_IDGenLabel24"
                                text="Movement Type"
                                design="Bold"
                            />
                            <!-- <m:Input
                                id="_IDGenInput4"
                                width="120px"
                                value="{Header>/MoveType}"
                                editable="false"
                            /> -->
                            <m:HBox id="_IDGenHBox1"
                                alignItems="Center"
                                renderType="Bare"
                            >
                                <m:Input
                                id="_IDGenInput4"
                                width="120px"
                                value="{Header>/MoveType}"
                                editable="false"
                            /> 
                                <m:Text
                                    id="_IDGenTextProdDesc1"
                                    text="{Header>/ProductDescription}"
                                    class="sapUiSmallMarginBegin"
                                />
                            </m:HBox>
                            <m:Label
                                id="_IDGenLabel261"
                                text="Department"
                            />
                            <m:Input
                                id="_IDGenInput101"
                                value="{Header>/WorkCenter}"
                                editable="false"
                            />

                            <m:Label
                                id="_IDGenLabel25"
                                text="Machine Number"
                            />
                            <m:Input
                                id="_IDGenInput9"
                                value="{Header>/HeaderText}"
                            />

                            <m:Label
                                id="_IDGenLabel26"
                                text="Shift/Operator"
                            />
                            <m:Input
                                id="_IDGenInput10"
                                value="{Header>/RefernceDocument}"
                            />

                            <!-- <m:Label
                                id="_IDGenLabel261"
                                text="PO Date"
                            />
                            <m:DatePicker
                                id="_IDGenInput101"
                                value="{Header>/PODate}"
                                valueFormat="yyyy-MM-ddTHH:mm:ss"
                                displayFormat="dd-MM-yyyy"
                            /> -->

                            <!-- <m:Label
                                
                                text="Order Type"
                            />
                            <m:Input
                                
                                value="{HEADER>/OrderType}"
                            /> -->
                        </f:content>
                    </f:SimpleForm>
                </m:content>
            </m:Panel>

            <m:Panel
                id="_IDGenPanel3"
                headerText="{= 'Material Details (' + ${Header>/ProdItemsCount} + ')'}"
                expandable="true"
                expanded="false"
                class="sapUiResponsiveMargin"
                width="auto"
            >
                <m:content>
                    <table:Table
                        id="_IDGenTable1"
                        rows="{Header>/ProdItems}"
                        selectionMode="MultiToggle"
                    >
                        <table:extension>
                            <m:OverflowToolbar id="_IDGenOverflowToolbar2">
                                <m:ToolbarSpacer id="_IDGenToolbarSpacer1" />
                                <m:Text
                                    id="_IDGenText13"
                                    text="Confirmed Qty - {Header>/ConfirmedTotalQty}"
                                />
                                <m:ToolbarSeparator
                                    id="_IDGenToolbarSeparator1"
                                />
                                <m:Text
                                    id="_IDGenText18"
                                    text="Total Required Qty - {Header>/FilledQty} / {Header>/AllOverQty}"
                                />
                                <m:ToolbarSeparator
                                    id="_IDGenToolbarSeparator2"
                                />

                                <!-- <m:Button
                                    id="_IDGenButton5"
                                    text="Generate Batch"
                                    press="GenerateBatches"
                                    type="Emphasized"
                                /> -->
                                <m:Button
                                    id="_IDGenButtonDelete"
                                    text="Delete"
                                    icon="sap-icon://delete"
                                    type="Reject"
                                    press="onDeleteRow"
                                />
                            </m:OverflowToolbar>
                        </table:extension>
                        <table:rowMode>
                            <rowmodes:Fixed
                                id="_IDGenFixed3"
                                rowCount="5"
                            />
                        </table:rowMode>
                        <table:columns>
                            <table:Column
                                id="_IDGenColumn12"
                                width="7rem"
                            >
                                <m:Label
                                    id="_IDGenLabel27"
                                    text="Material"
                                />
                                <table:template>
                                    <m:Text
                                        id="_IDGenText10"
                                        text="{Header>Material}"
                                    />
                                </table:template>
                            </table:Column>
                            <table:Column
                                id="_IDGenColumn26"
                                width="8rem"
                            >
                                <m:Label
                                    id="_IDGenLabel36"
                                    text="Name"
                                />
                                <table:template>
                                    <m:Text
                                        id="_IDGenText17"
                                        text="{Header>ProductName}"
                                    />
                                </table:template>
                            </table:Column>
                            <table:Column
                                id="_IDGenColumn20"
                                width="4rem"
                            >
                                <m:Label
                                    id="_IDGenLabel32"
                                    text="Plant"
                                />
                                <table:template>
                                    <m:Text
                                        id="_IDGenText15"
                                        text="{Header>Plant}"
                                    />
                                </table:template>
                            </table:Column>
                            <table:Column
                                id="_IDGenColumn21"
                                width="6rem"
                            >
                                <m:Label
                                    id="_IDGenLabel33"
                                    text="Storage Location"
                                />
                                <table:template>
                                    <m:Input
                                        id="_IDGenText16"
                                        value="{Header>Location}"
                                        submit="onRowEnter"
                                    />
                                </table:template>
                            </table:Column>
                            <table:Column
                                id="_IDGenColumn22"
                                width="8rem"
                            >
                                <m:Label
                                    id="_IDGenLabel34"
                                    text="Batch Number"
                                />
                                <table:template>
                                    <m:Input
                                        id="_IDGenInput11"
                                        value="{Header>Batch}"
                                        editable="false"
                                        submit="onRowEnter"
                                    />
                                </table:template>
                            </table:Column>

                            <table:Column
                                id="_IDGenColumn16"
                                width="6rem"
                            >
                                <m:Label
                                    id="_IDGenLabel28"
                                    text="Quantity"
                                />
                                <table:template>
                                    <m:Input
                                        id="_IDGenText11"
                                        value="{Header>Quantity}"
                                        change="qtyChange"
                                        type="Number"
                                        submit="onRowEnter"
                                    />
                                </table:template>
                            </table:Column>
                            <table:Column
                                id="_IDGenColumn17"
                                width="4rem"
                            >
                                <m:Label
                                    id="_IDGenLabel29"
                                    text="Unit"
                                />
                                <table:template>
                                    <m:Text
                                        id="_IDGenText12"
                                        text="{Header>Unit}"
                                    />
                                </table:template>
                            </table:Column>
                            <table:Column
                                id="_IDGenColumn171"
                                width="8rem"
                            >
                                <m:Label
                                    id="_IDGenLabel291"
                                    text="Converted Quantity"
                                />
                                <table:template>
                                    <m:Text
                                        id="_IDGenText121"
                                        text="{Header>ConvertedQuantity}"
                                    />
                                </table:template>
                            </table:Column>
                             <table:Column
                                id="_IDGenColumn811"
                                width="10rem"
                            >
                                <m:Label
                                    id="_IDGenLabel1511"
                                    text="Converted Unit"
                                />
                                <table:template>
                                    <m:Text
                                        id="_IDGenInput511"
                                        text="{Header>AlternativeUnit}"
                                    />
                                </table:template>
                            </table:Column>
                            <!-- <table:Column
                                id="_IDGenColumn18"
                                width="15rem"
                            >
                                <m:Label
                                    id="_IDGenLabel30"
                                    text="Movement Type"
                                />
                                <table:template>
                                    <m:Text
                                        id="_IDGenText13"
                                        text="{Header>MoveType}"
                                    />
                                </table:template>
                            </table:Column> -->
                        </table:columns>
                    </table:Table>
                </m:content>
            </m:Panel>
        </m:content>

        <m:footer>
            <m:OverflowToolbar id="_IDGenOverflowToolbar">
                <m:ToolbarSpacer id="_IDGenToolbarSpacer" />
                <!-- <m:Button
                    id="_IDGenButton"
                    text="Check"
                    type="Emphasized"
                    press=".onCheck"
                /> -->
                <m:Button
                    id="_IDGenButton3"
                    text="Post"
                    type="Emphasized"
                    press=".onPost"
                />
                <m:Button
                    id="_IDGenButton4"
                    text="Cancel"
                    press="onCancel"
                    type="Ghost"
                />
            </m:OverflowToolbar>
        </m:footer>
    </m:Page>
</mvc:View>












